# ===== APPLICATION CONFIGURATION =====

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://calc-hub.site
NODE_ENV=production

# ----- Database -----
# PostgreSQL connection string (update with your credentials)
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ----- Authentication -----
# JWT secret for admin panel (generate a strong random string)
JWT_SECRET=your-jwt-secret-here

# ----- Email (Resend) -----
# Get your API key from https://resend.com/api-keys
EMAIL_API_KEY=re_xxxxxxxxxxxxx
# Verified sender email from Resend
EMAIL_FROM=onboarding@resend.dev

# ----- Admin Panel -----
# Admin credentials for login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password

# ===== SEO & ANALYTICS =====

# Google Search Console Verification
# Get this from: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Google Analytics
# Get your tracking ID from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager (Optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXXX

# Bing Webmaster Tools (Optional)
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code

# ===== PUBLIC (Client-Side) =====

# ----- Monetag Ads -----
# Get from https://monetag.com
NEXT_PUBLIC_MONETAG_SRC=https://example.com/script.js
NEXT_PUBLIC_MONETAG_ZONE=your-monetag-zone-id
