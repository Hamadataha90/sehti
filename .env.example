# =============================================
# صِحتي - Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ----- Database -----
# SQLite (local development):
# DATABASE_URL=file:./db/custom.db
# PostgreSQL (production - Neon):
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# ----- Authentication -----
# JWT secret for admin panel (generate a strong random string)
JWT_SECRET=your-jwt-secret-here

# ----- Email (Resend) -----
# Get your API key from https://resend.com/api-keys
EMAIL_API_KEY=re_xxxxxxxxxxxxx
# Verified sender email from Resend
EMAIL_FROM=onboarding@resend.dev

# ----- Admin Panel -----
# Admin credentials for login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password

# ----- Public (Client-Side) -----
# Your deployed site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ----- Monetag Ads -----
# Get from https://monetag.com
NEXT_PUBLIC_MONETAG_SRC=https://example.com/script.js
NEXT_PUBLIC_MONETAG_ZONE=your-monetag-zone-id
